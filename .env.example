# ------------------------------------------------------------
# Lugu Lake Guide - environment template
# 1) Copy this file to .env
# 2) Fill in required secrets (at least SECRET_KEY and DASHSCOPE_API_KEY)
# ------------------------------------------------------------

# PostgreSQL (docker-compose db service)
POSTGRES_DB=lugu_lake
POSTGRES_USER=lugu
POSTGRES_PASSWORD=change-me-db-password
# Host port exposed for external tools (psql, DBeaver, etc.)
POSTGRES_HOST_PORT=15432
DB_BIND_HOST=127.0.0.1
# Internal port used by backend container to connect db service.
# In docker-compose mode this should remain 5432.
DB_HOST=db
DB_PORT=5432

# Service ports exposed on host
BACKEND_PORT=18000
BACKEND_BIND_HOST=127.0.0.1
FRONTEND_BIND_HOST=0.0.0.0
FRONTEND_PORT=5173

# Backend app settings
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256
ALLOWED_HOSTS=*

# Cookie/CSRF session security
USER_SESSION_COOKIE_NAME=lugu_user_session
ADMIN_SESSION_COOKIE_NAME=lugu_admin_session
CSRF_COOKIE_NAME=lugu_csrf_token
CSRF_HEADER_NAME=x-csrf-token
CSRF_COOKIE_TTL_MINUTES=1440
ENFORCE_CSRF=true
PASSWORD_TRANSPORT_ENCRYPTION_ENABLED=true
PASSWORD_TRANSPORT_PUBLIC_KEY_PEM=
PASSWORD_TRANSPORT_PRIVATE_KEY_PEM=
PASSWORD_TRANSPORT_ALLOW_PLAINTEXT_FALLBACK=true
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=

# Seed admin account (used by backend/scripts/seed.py)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123

# AI provider (DashScope)
# Leave empty to use backend fallback replies based on local knowledge base.
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# Backend local storage path (inside backend container)
UPLOAD_DIR=/app/uploads

# CORS origins for backend API.
# Use * for quick verification, then tighten to your real domain list in production.
CORS_ORIGINS=*

# Frontend vars
# Browser direct API base (used by src/api.js).
# Keep empty to use same-origin path (/api, /uploads) behind reverse proxy.
VITE_API_BASE_URL=
VITE_CSRF_COOKIE_NAME=lugu_csrf_token
VITE_CSRF_HEADER_NAME=X-CSRF-Token

# 高德地图 API Key (需要从高德地图开放平台获取)
# https://lbs.amap.com/dev/key/app
VITE_AMAP_KEY=
# 高德地图安全密钥 (securityJsCode)
VITE_AMAP_SECURITY_JS_CODE=

# Vite dev proxy target (used by frontend/vite.config.js)
# Docker:  http://backend:8000
# Local:   http://127.0.0.1:8000
VITE_PROXY_TARGET=http://backend:8000
